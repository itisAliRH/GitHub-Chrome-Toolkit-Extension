{
  "name": "github-chrome-toolkit-extension",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "esbuild src/notifications/index.ts src/pull-request/index.ts src/service-worker.ts --bundle --platform=browser --outdir=dist --outbase=src",
    "watch": "esbuild src/notifications/index.ts src/pull-request/index.ts src/service-worker.ts --bundle --platform=browser --outdir=dist --outbase=src --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "Filter notifications, open in tabs, and delete branches — right from the page.",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "chrome-types": "^0.1.425",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "esbuild": "^0.27.4"
  }
}
